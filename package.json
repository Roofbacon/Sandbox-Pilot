{
  "name": "sandbox-pilot",
  "version": "0.3.0",
  "description": "Sandbox Pilot — an MCP server that lets an AI see, click, type, scroll, OCR and build guides inside a disposable Windows Sandbox.",
  "type": "module",
  "bin": {
    "sandbox-pilot": "dist/index.js"
  },
  "files": [
    "dist",
    "host",
    "guest",
    "bridge/BootstrapWinget.ps1",
    "bridge/CheckAdobeStatus.ps1",
    "bridge/InstallTesseract.ps1",
    "bridge/KillPowerShellProcesses.cmd",
    "bridge/ListProcesses.cmd"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Roofbacon/Sandbox-Pilot.git"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "windows-sandbox",
    "automation",
    "ui-automation",
    "ocr"
  ],
  "scripts": {
    "build": "tsc",
    "prepare": "tsc",
    "start": "node dist/index.js",
    "dev": "tsc --watch",
    "pretest": "tsc",
    "test": "node --test test/*.test.mjs"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "pdf-lib": "^1.17.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.6.0"
  }
}
